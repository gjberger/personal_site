---
import Base from "../../layouts/Base.astro";

const items = [
  {
    title: "The Trainer",
    href: "/private/trainer/",
    role: "one step at a time",
    body: `The plan as a campaign: it greets me, hands me the single next step, and
      I mark it done. Weeks unlock by shipping, not by the calendar. Installable
      from the share sheet as its own app; same synced state as the plan.`,
  },
  {
    title: "The Training Plan",
    href: "/private/plan/",
    role: "twelve weeks, tracked",
    body: `The summer-to-fall plan: the Jetson build ladder, the daily drills, the
      recruiting timeline, the ADHD scaffolding. Checkboxes sync across my devices,
      and the week only counts when its ship is public.`,
  },
  {
    title: "The Drills",
    href: "/private/drills/",
    role: "the daily fifteen",
    body: `Timed retrieval on the GPU and kernel material: 110 prompts across
      eleven decks mapped to the campaign weeks, plus the LeetCode and probability
      floor. Reveal, grade, log a miss. Scores and misses sync into the same log
      the Trainer and Plan read.`,
  },
  {
    title: "The Explorable Atlas",
    href: "/private/atlas/",
    role: "sixteen interactive labs",
    body: `The GPU and AI half of the system: a hands-on tour from a single die to
      a transformer running in the browser, parallelism through warps, memory,
      tensor cores, backprop, attention, and CUDA on the Orin. Nothing is a video;
      every diagram runs, and I drive it. Algorithms and linear algebra hand off to
      the Algo Lab.`,
  },
  {
    title: "Algorithm Lab",
    href: "/private/algolab/",
    role: "two tracks, drilled and proven",
    body: `The other half: algorithms (foundations through NP-hardness, FFT,
      flow, sketching) and advanced linear algebra (spectral theory, SVD, Cholesky,
      conditioning, the numerical core ML systems run on). Every lesson makes me
      predict before it plays, times my drills, and machine-checks the proofs. A
      placement diagnostic skips what CS 161, CME 213, and Math 51 already gave me,
      so I only drill the rungs above my line.`,
  },
];
---

<Base path="/private" title="Private" description="A private workspace.">
  <div class="wrap wrap--wide">
    <h1>Private</h1>
    <p class="muted lede">
      A corner of the site kept for myself — the work still in progress, and the
      structure I use to hold myself to it.
    </p>

    {
      items.map((it) => (
        <div class="entry">
          <div class="head">
            <h3><a href={it.href}>{it.title}</a></h3>
          </div>
          <p class="role">{it.role}</p>
          <p>{it.body}</p>
          <div class="actions">
            <a href={it.href}>open &rarr;</a>
          </div>
        </div>
      ))
    }
  </div>
</Base>
