---
import Base from "../../layouts/Base.astro";

const items = [
  {
    title: "Algorithm Lab",
    href: "/private/algolab/",
    role: "the whole system, one door",
    body: `Three tracks, all prediction-first: algorithms (foundations through
      NP-hardness, FFT, flow, sketching), advanced linear algebra (spectral theory,
      SVD, conditioning — the numerical core ML systems run on), and the GPU / AI
      infrastructure path: sixteen studios from launch geometry through tensor
      cores, FlashAttention, collectives, sharding, serving, TPUs, and training
      economics, with graded predictions, timed drills, spaced review, and the
      papers attached to the arithmetic they explain. Placement diagnostics skip
      what CS 161, CME 213, and Math 51 already gave me.`,
  },
];
---

<Base path="/private" title="Private" description="A private workspace.">
  <div class="wrap wrap--wide">
    <h1>Private</h1>
    <p class="muted lede">
      A corner of the site kept for myself — one lab, kept sharp.
    </p>

    {
      items.map((it) => (
        <div class="entry">
          <div class="head">
            <h3><a href={it.href}>{it.title}</a></h3>
          </div>
          <p class="role">{it.role}</p>
          <p>{it.body}</p>
          <div class="actions">
            <a href={it.href}>open &rarr;</a>
          </div>
        </div>
      ))
    }
  </div>
</Base>
