---
import "../styles/global.css";

const {
  title = "Gabriel Berger",
  description = "Gabriel Berger — undergraduate at Stanford studying math, computer science, and statistics. Low-level systems work, plus research in cancer genomics.",
  path = "/",
} = Astro.props;

const site = "https://gabrieljberger.com";
const url = new URL(path, site).href;

const nav = [
  { href: "/", label: "home" },
  { href: "/projects", label: "projects" },
  { href: "/research", label: "research" },
  { href: "/writing", label: "writing" },
  { href: "/resume", label: "résumé" },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === "Gabriel Berger" ? title : `${title} · Gabriel Berger`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta name="author" content="Gabriel Berger" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="Gabriel Berger" />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Fraunces:opsz,wght@9..144,400;9..144,500&display=swap"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#faf7f1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1916" media="(prefers-color-scheme: dark)" />
  </head>
  <body>
    <header class="site">
      <div class="site-inner">
        <a class="wordmark" href="/">Gabriel Berger</a>
        <nav class="site-nav" aria-label="Primary">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={
                  (item.href === "/" ? current === "/" : current.startsWith(item.href))
                    ? "page"
                    : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} Gabriel Berger</span>
        <span>
          <a href="mailto:gberger@stanford.edu">email</a> ·
          <a href="https://github.com/gjberger">github</a> ·
          <a href="https://www.linkedin.com/in/gabriel-berger-69968a336/">linkedin</a>
        </span>
      </div>
    </footer>
  </body>
</html>
